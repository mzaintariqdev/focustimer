{
  "expo": {
    "name": "FocusTimer",
    "slug": "FocusTimer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7FF"
    },
    "android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/icon.png",
    "backgroundColor": "#6C63FF"
  },
      "package": "com.yourname.focustimer",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C63FF",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ca8577c9-8e7f-43c8-9c9c-f10519e535b8"
      }
    }
  }
}
